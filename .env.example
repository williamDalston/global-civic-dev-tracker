# ===========================================
# REQUIRED ENVIRONMENT VARIABLES
# ===========================================

# Database (Neon PostgreSQL)
# Get your connection string from https://neon.tech
DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Site URL (used for meta tags, sitemaps, canonical URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI API Key (for AI narrative generation)
# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Authentication secrets (generate secure random strings)
# CRON_SECRET is also used as the admin dashboard password
CRON_SECRET=your-cron-secret-min-32-chars
REVALIDATION_SECRET=your-revalidation-secret-min-32-chars

# ===========================================
# RECOMMENDED ENVIRONMENT VARIABLES
# ===========================================

# IndexNow Key (for faster search engine indexing)
# Generate a UUID: uuidgen or https://www.uuidgenerator.net/
# After setting, verify at: https://www.bing.com/indexnow
INDEXNOW_KEY=your-indexnow-key-uuid

# Email notifications via Resend (for lead alerts)
# Get your API key from https://resend.com
RESEND_API_KEY=re_...

# Email address to receive lead notifications
ADMIN_EMAIL=info@alstonanalytics.com

# ===========================================
# OPTIONAL ENVIRONMENT VARIABLES
# ===========================================

# City API tokens (increases rate limits for data fetching)
# Washington DC: https://opendata.dc.gov
WASHINGTON_DC_API_TOKEN=

# NYC Open Data: https://opendata.cityofnewyork.us
NYC_API_TOKEN=

# Chicago Data Portal: https://data.cityofchicago.org
CHICAGO_API_TOKEN=

# Sydney Planning Portal: https://www.planningportal.nsw.gov.au
SYDNEY_API_TOKEN=

# Google Search Console credentials (for page pruning feature)
# Export service account JSON and base64 encode it
# GOOGLE_SEARCH_CONSOLE_CREDENTIALS=

# Debug mode for ETL (set to "true" for verbose logging)
# ETL_DEBUG=true

# ===========================================
# ANALYTICS (choose one or both)
# ===========================================

# Google Analytics 4 Measurement ID
# Get from: https://analytics.google.com > Admin > Data Streams
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Plausible Analytics domain (privacy-friendly alternative)
# Sign up at: https://plausible.io
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yourdomain.com

# ===========================================
# MONETIZATION
# ===========================================

# Stripe Secret Key (for contractor billing)
# Get from: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_...

# Stripe Webhook Secret (for verifying webhook signatures)
# Get from: https://dashboard.stripe.com/webhooks
# STRIPE_WEBHOOK_SECRET=whsec_...

# Google AdSense Publisher ID (for display ads)
# Get from: https://adsense.google.com > Account > Publisher ID
# Renders nothing if not set — safe to leave blank until approved
# NEXT_PUBLIC_ADSENSE_PUB_ID=ca-pub-XXXXXXXXXXXXXXXX
